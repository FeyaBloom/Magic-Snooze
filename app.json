{
  "expo": {
    "name": "Magic Snooze",
    "slug": "magic-snooze",
    "version": "1.0.7",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "magic-snooze",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-foreground.png",
        "backgroundImage": "./assets/icon-background.png"
      },
      "package": "com.feya_bloom.magic_snooze",
      "permissions": [
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "RECORD_AUDIO"
      ]
    },
    "androidNavigationBar": {
      "backgroundColor": "#00000000",
      "barStyle": "dark-content"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "backgroundColor": "#000000",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-font",
        {
          "assets": [
            "./assets/fonts/Cormorant-Regular.ttf",
            "./assets/fonts/Cormorant-Medium.ttf",
            "./assets/fonts/Cormorant-MediumItalic.ttf",
            "./assets/fonts/Cormorant-SemiBold.ttf",
            "./assets/fonts/Cormorant-Bold.ttf",
            "./assets/fonts/Nunito-Regular.ttf",
            "./assets/fonts/Nunito-SemiBold.ttf",
            "./assets/fonts/Nunito-Bold.ttf"
          ]
        }
      ],
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F59E0B",
          "sounds": [],
          "mode": "default"
        }
      ],
      "expo-audio",
      "expo-asset",
      "expo-image-picker",
      "./plugins/withAndroid15BootCompliance",
      "./plugins/withLargeScreenOrientationCompliance",
      "./plugins/withDynamicSystemBars"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cef7c5a9-2aa0-4f63-a843-c61f3ece8ce1"
      }
    },
    "owner": "feya-bloom-studio"
  }
}
